---
const stats = [
  { n: '240+', l: '部署单元 / UNITS' },
  { n: '1.2M km', l: '累计任务里程 / MILEAGE' },
  { n: '128', l: 'OTA 迭代 / RELEASES' },
  { n: '99.97%', l: '集群可用率 / UPTIME' },
];
---

<section id="top" class="blueprint relative overflow-hidden pt-16">
  <div
    class="mx-auto grid max-w-6xl items-center gap-12 px-[var(--gutter)] pb-14 pt-16 lg:grid-cols-[1.05fr_0.95fr] lg:gap-8 lg:pt-24"
  >
    <!-- 左：品牌主张 -->
    <div class="relative z-10">
      <p class="tag tag--acc flex items-center gap-3">
        <span class="dot"></span>
        AGENTS GROW WELL · FLEET ONLINE
      </p>

      <h1 class="disp mt-6 leading-none" style="font-size: clamp(4.5rem, 13vw, 9rem);">
        AGW
      </h1>

      <p
        class="mt-4 text-3xl font-bold leading-snug tracking-wide md:text-4xl"
      >
        持续进化的<span class="text-acc">实体机器人</span>集群
      </p>

      <p class="mt-6 max-w-lg text-mut">
        从园区巡检到农田作业，AGW
        的每一台机器都在任务中学习——数据回流、云端训练、整队升级。一台学会的，整个集群都会。
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a href="#visit" class="btn btn--solid">
          预约线下展厅 <span class="arr">→</span>
        </a>
        <a href="#fleet" class="btn">查看产品矩阵</a>
      </div>
    </div>

    <!-- 右：工程蓝图 -->
    <div class="corner relative overflow-hidden border border-line bg-panel/60">
      <img
        src="/images/agw-robot-blueprint.png"
        alt="AGW-S1 巡检机器人与人形机器人工程蓝图"
        class="block h-auto w-full"
        width="512"
        height="475"
        loading="eager"
        decoding="async"
      />
      <div class="hidden" aria-hidden="true">
      <div class="scanline"></div>
      <div class="mb-4 flex items-center justify-between">
        <span class="tag">FIG. 01 — AGW-S1 · 自主巡检单元</span>
        <span class="tag tag--acc">SCALE 1:20</span>
      </div>

      <svg
        viewBox="0 0 460 380"
        class="hero-bot mx-auto w-full max-w-md"
        role="img"
        aria-label="AGW-S1 巡检机器人与 AGW-H1 人形机器人工程图"
        fill="none"
        stroke-linecap="round"
      >
        <!-- 底盘 -->
        <rect x="100" y="228" width="260" height="78" rx="12" stroke="var(--color-ink)" stroke-width="1.6"/>
        <line x1="100" y1="252" x2="360" y2="252" stroke="var(--color-line)" stroke-width="1.4"/>
        <rect x="118" y="264" width="52" height="26" rx="3" stroke="var(--color-mut)" stroke-width="1"/>
        <rect x="290" y="264" width="52" height="26" rx="3" stroke="var(--color-mut)" stroke-width="1"/>
        <!-- 轮组 -->
        <circle cx="152" cy="316" r="30" stroke="var(--color-ink)" stroke-width="1.6"/>
        <circle cx="152" cy="316" r="12" stroke="var(--color-acc)" stroke-width="1.6"/>
        <circle cx="308" cy="316" r="30" stroke="var(--color-ink)" stroke-width="1.6"/>
        <circle cx="308" cy="316" r="12" stroke="var(--color-acc)" stroke-width="1.6"/>
        <!-- 立柱与传感头 -->
        <line x1="230" y1="228" x2="230" y2="140" stroke="var(--color-ink)" stroke-width="1.6"/>
        <rect x="196" y="96" width="68" height="46" rx="8" stroke="var(--color-ink)" stroke-width="1.6"/>
        <circle cx="230" cy="119" r="9" stroke="var(--color-acc)" stroke-width="1.6"/>
        <circle cx="230" cy="119" r="2.5" fill="var(--color-acc)"/>
        <!-- 激光雷达 -->
        <rect x="212" y="70" width="36" height="18" rx="4" stroke="var(--color-acc)" stroke-width="1.6"/>
        <path d="M212 60 A46 46 0 0 1 248 60" stroke="var(--color-acc)" stroke-width="1" stroke-dasharray="3 5"/>
        <path d="M200 48 A66 66 0 0 1 260 48" stroke="var(--color-acc)" stroke-width="1" stroke-dasharray="3 5" opacity="0.5"/>
        <!-- 机械臂 -->
        <circle cx="316" cy="228" r="7" stroke="var(--color-ink)" stroke-width="1.6"/>
        <line x1="316" y1="228" x2="338" y2="207" stroke="var(--color-ink)" stroke-width="1.6"/>
        <circle cx="338" cy="207" r="5" stroke="var(--color-ink)" stroke-width="1.6"/>
        <!-- 尺寸标注：总宽 -->
        <line x1="100" y1="356" x2="360" y2="356" stroke="var(--color-mut)" stroke-width="1" stroke-dasharray="4 4"/>
        <line x1="100" y1="350" x2="100" y2="362" stroke="var(--color-mut)" stroke-width="1"/>
        <line x1="360" y1="350" x2="360" y2="362" stroke="var(--color-mut)" stroke-width="1"/>
        <text x="230" y="349" text-anchor="middle" class="dim">1180 mm</text>
        <!-- 尺寸标注：总高 -->
        <line x1="64" y1="70" x2="64" y2="346" stroke="var(--color-mut)" stroke-width="1" stroke-dasharray="4 4"/>
        <line x1="58" y1="70" x2="70" y2="70" stroke="var(--color-mut)" stroke-width="1"/>
        <line x1="58" y1="346" x2="70" y2="346" stroke="var(--color-mut)" stroke-width="1"/>
        <text x="52" y="212" text-anchor="middle" class="dim" transform="rotate(-90 52 212)">920 mm</text>
        <!-- 标注引线：雷达 -->
        <line x1="248" y1="79" x2="330" y2="62" stroke="var(--color-mut)" stroke-width="1"/>
        <text x="336" y="65" class="dim" fill="var(--color-acc)">LIDAR 360°</text>

        <!-- AGW-H1 人形机器人：参考工业人形机器人装甲结构 -->
        <g class="humanoid" transform="translate(25 2) scale(.9)" stroke="var(--color-ink)" stroke-width="1.35">
          <!-- 圆顶头盔与视觉面罩 -->
          <path d="M356 70 Q357 45 379 40 Q401 44 404 68 L401 94 Q394 108 379 111 Q364 108 357 94 Z" fill="var(--color-panel)"/>
          <path d="M361 63 Q379 54 399 64 L397 81 Q379 87 361 80 Z" fill="var(--color-bg)" stroke="var(--color-mut)"/>
          <path d="M365 68 h22" stroke="var(--color-acc)" stroke-width="2.2"/>
          <circle cx="399" cy="73" r="8" fill="var(--color-panel)"/>
          <circle cx="399" cy="73" r="3" stroke="var(--color-acc)"/>
          <path d="M370 110 v10 h18 v-10" fill="var(--color-panel)"/>

          <!-- 肩部、胸甲与腰部 -->
          <circle cx="343" cy="135" r="14" fill="var(--color-panel)"/>
          <circle cx="343" cy="135" r="6" stroke="var(--color-acc)"/>
          <circle cx="415" cy="135" r="14" fill="var(--color-panel)"/>
          <circle cx="415" cy="135" r="6" stroke="var(--color-acc)"/>
          <path d="M351 125 Q379 112 407 125 L411 164 L400 199 Q379 214 358 199 L347 164 Z" fill="var(--color-panel)"/>
          <path d="M357 136 Q379 125 401 136 L398 174 Q379 186 360 174 Z" fill="var(--color-bg)" stroke="var(--color-mut)"/>
          <rect x="370" y="143" width="19" height="7" rx="3.5" stroke="var(--color-acc)"/>
          <path d="M360 190 Q379 201 398 190 L394 216 Q379 224 364 216 Z" fill="var(--color-bg)"/>
          <circle cx="379" cy="207" r="4" stroke="var(--color-acc)"/>

          <!-- 分段式机械手臂 -->
          <path d="M331 146 Q341 140 350 147 L340 188 Q332 196 323 189 Z" fill="var(--color-panel)"/>
          <circle cx="331" cy="196" r="9" fill="var(--color-panel)"/>
          <circle cx="331" cy="196" r="3.5" stroke="var(--color-acc)"/>
          <path d="M323 205 Q331 200 339 206 L337 246 Q330 254 322 247 Z" fill="var(--color-panel)"/>
          <path d="M325 249 l-6 12 m10 -10 v13 m4 -14 l6 11" stroke-width="1.1"/>
          <path d="M408 147 Q417 140 427 146 L435 189 Q426 196 418 188 Z" fill="var(--color-panel)"/>
          <circle cx="427" cy="196" r="9" fill="var(--color-panel)"/>
          <circle cx="427" cy="196" r="3.5" stroke="var(--color-acc)"/>
          <path d="M419 206 Q427 200 435 205 L436 247 Q428 254 421 246 Z" fill="var(--color-panel)"/>
          <path d="M433 249 l6 12 m-10 -10 v13 m-4 -14 l-6 11" stroke-width="1.1"/>

          <!-- 骨盆、腿甲、膝关节与机械靴 -->
          <path d="M360 217 Q379 228 398 217 L403 239 Q393 251 379 248 Q365 251 355 239 Z" fill="var(--color-panel)"/>
          <circle cx="365" cy="242" r="9" fill="var(--color-panel)"/>
          <circle cx="393" cy="242" r="9" fill="var(--color-panel)"/>
          <path d="M355 251 Q365 245 374 252 L369 289 Q363 298 353 290 Z" fill="var(--color-panel)"/>
          <path d="M384 252 Q393 245 403 251 L405 290 Q395 298 389 289 Z" fill="var(--color-panel)"/>
          <circle cx="360" cy="297" r="10" fill="var(--color-panel)"/>
          <circle cx="398" cy="297" r="10" fill="var(--color-panel)"/>
          <circle cx="360" cy="297" r="4" stroke="var(--color-acc)"/>
          <circle cx="398" cy="297" r="4" stroke="var(--color-acc)"/>
          <path d="M352 307 Q360 301 368 308 L369 341 L363 351 H347 L350 332 Z" fill="var(--color-panel)"/>
          <path d="M390 308 Q398 301 406 307 L408 332 L411 351 H395 L389 341 Z" fill="var(--color-panel)"/>
          <path d="M347 350 q-14 3 -21 13 q18 4 43 0 l-6 -13" fill="var(--color-panel)"/>
          <path d="M411 350 q14 3 21 13 q-18 4 -43 0 l6 -13" fill="var(--color-panel)"/>

          <!-- 高度标注 -->
          <line x1="448" y1="42" x2="448" y2="364" stroke="var(--color-mut)" stroke-width="1" stroke-dasharray="4 4"/>
          <line x1="442" y1="42" x2="454" y2="42" stroke="var(--color-mut)"/>
          <line x1="442" y1="364" x2="454" y2="364" stroke="var(--color-mut)"/>
          <text x="459" y="205" text-anchor="middle" class="dim" transform="rotate(-90 459 205)" stroke="none">1750 mm</text>
        </g>
        <!-- 十字定位标 -->
        <path d="M425 330 h14 M432 323 v14" stroke="var(--color-mut)" stroke-width="1"/>
        <path d="M30 30 h14 M37 23 v14" stroke="var(--color-mut)" stroke-width="1"/>
      </svg>

      <div class="mt-4 flex items-center justify-between border-t border-line pt-4">
        <span class="tag">DWG NO. AGW-S1-2026-04</span>
        <span class="tag">REV 4.2</span>
      </div>
      </div>
    </div>
  </div>

  <!-- 参数横条 -->
  <div class="border-t border-line">
    <div
      class="mx-auto grid max-w-6xl grid-cols-2 divide-x divide-line md:grid-cols-4"
    >
      {
        stats.map((s) => (
          <div class="px-[var(--gutter)] py-6 first:pl-[var(--gutter)]">
            <div class="font-mono text-2xl font-medium text-acc md:text-3xl">
              {s.n}
            </div>
            <div class="tag mt-1">{s.l}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .hero-bot {
    animation: bot-float 6s ease-in-out infinite;
  }
  .hero-bot .dim {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--color-mut);
    letter-spacing: 0.08em;
  }
  @keyframes bot-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-bot { animation: none; }
  }
</style>
