---
const nav = [
  { href: '#fleet', label: '产品矩阵' },
  { href: '#scenarios', label: '场景方案' },
  { href: '#evolution', label: '进化闭环' },
  { href: '#cases', label: '客户案例' },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-line bg-bg/85 backdrop-blur-md"
>
  <div
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-[var(--gutter)]"
  >
    <a href="#top" class="flex items-center gap-3">
      <svg width="26" height="26" viewBox="0 0 32 32" aria-hidden="true">
        <path
          d="M5 5h6v2H7v4H5V5zm22 0v6h-2V7h-4V5h6zM5 27v-6h2v4h4v2H5zm22 0h-6v-2h4v-4h2v6z"
          fill="var(--color-acc)"></path>
        <circle
          cx="16"
          cy="16"
          r="4.5"
          fill="none"
          stroke="var(--color-acc)"
          stroke-width="2"></circle>
        <circle cx="16" cy="16" r="1.5" fill="var(--color-acc)"></circle>
      </svg>
      <span class="disp text-sm tracking-[0.2em]">AGW<span class="text-acc">.</span>BOT</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="tag transition-colors duration-200 hover:text-acc"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a href="#visit" class="btn !px-4 !py-2 text-xs">预约展厅</a>
  </div>
</header>
